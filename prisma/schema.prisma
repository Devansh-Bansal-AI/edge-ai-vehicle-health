datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  users     User[]
  vehicles  Vehicle[]
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  tenantId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Vehicle {
  id          String              @id @default(cuid())
  name        String
  vin         String              @unique
  tenantId    String
  createdAt   DateTime            @default(now())
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  anomalies   AnomalyEvent[]
  maintenance MaintenanceRecord[]
  snapshots   HealthSnapshot[]
  diagnostic  DiagnosticSession[]

  @@index([tenantId])
}

model AnomalyEvent {
  id        String   @id @default(cuid())
  vehicleId String
  sensor    String
  faultType String
  zScore    Float
  severity  String
  duration  Int
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, createdAt(sort: Desc)])
  @@index([vehicleId, sensor, createdAt(sort: Desc)])
}

model MaintenanceRecord {
  id          String    @id @default(cuid())
  vehicleId   String
  component   String
  rulDays     Int
  servicedAt  DateTime?
  createdAt   DateTime  @default(now())
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([component])
}

model HealthSnapshot {
  id        String   @id @default(cuid())
  vehicleId String
  score     Float
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, createdAt(sort: Desc)])
}

model DiagnosticSession {
  id        String   @id @default(cuid())
  vehicleId String
  messages  Json
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, createdAt(sort: Desc)])
}
